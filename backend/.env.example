# GitHub — optional but recommended (unauthenticated search is rate-limited to ~10 req/min)
GITHUB_TOKEN=

# PatentsView — required for the patents connector to run (free signup)
# https://search.patentsview.org/api/keyrequest/
PATENTSVIEW_API_KEY=

# Exa — required for the exa_search connector (domain-restricted LinkedIn URL
# discovery + reform-agent deep general search). Get a key at https://exa.ai
EXA_API_KEY=

# ScrapeCreators — Instagram profile + handle search
# https://app.scrapecreators.com (header: x-api-key)
SCRAPECREATORS_API_KEY=

# APIDirect — optional Instagram posts enrichment by keyword/handle
# https://apidirect.io (header: X-API-Key)
APIDIRECT_API_KEY=

# Gemini — required for reform agent, web search, and summary
# (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Optional override, defaults to gemini-2.5-flash
GEMINI_MODEL=

# LinkedIn public-profile reader — off by default. Reads ONE known profile URL,
# logged-out, single request; the post/activity feed is confirmed login-gated
# and is never accessed regardless of this flag.
ENABLE_LINKEDIN_PUBLIC_READ=false

# How many hours a searched profile's data stays "fresh" before a repeat search
# re-fetches it. Use --force-refresh on the CLI to bypass for one run.
CACHE_TTL_HOURS=24

# Mobile API
API_JWT_SECRET=change-me-in-production
STARTING_TOKENS=15
